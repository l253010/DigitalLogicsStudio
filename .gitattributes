# Normalize line endings for all text files to LF in the repo,
# and let Git handle checkout conversion per-platform.
* text=auto eol=lf

# Explicitly LF for web source files
*.js        text eol=lf
*.jsx       text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.xml       text eol=lf
*.svg       text eol=lf
*.env       text eol=lf
*.env.*     text eol=lf
*.gitignore text eol=lf

# Binary files — never touch line endings
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.eot  binary
*.otf  binary
*.pdf  binary
*.zip  binary
*.gz   binary
